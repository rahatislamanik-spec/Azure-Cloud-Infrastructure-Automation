{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Azure Cloud Infrastructure — NSG ARM Template",
    "project": "Azure Cloud Infrastructure & Automation",
    "author": "Md Rahat Islam Anik"
  },
  "parameters": {
    "nsgName": {
      "type": "string",
      "defaultValue": "AzureInfra-NSG",
      "metadata": {
        "description": "Name of the Network Security Group"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for resource deployment"
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "Lab",
      "allowedValues": ["Lab", "Development", "Production"],
      "metadata": {
        "description": "Deployment environment tag"
      }
    }
  },
  "variables": {
    "allowHttpsRuleName": "Allow-HTTPS-Inbound",
    "allowAzureServicesRuleName": "Allow-AzureServices",
    "denyAllRuleName": "Deny-All-Inbound"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-04-01",
      "name": "[parameters('nsgName')]",
      "location": "[parameters('location')]",
      "tags": {
        "Environment": "[parameters('environment')]",
        "Project": "AzureInfraAutomation",
        "Owner": "IT-Operations",
        "ManagedBy": "ARM-Template"
      },
      "properties": {
        "securityRules": [
          {
            "name": "[variables('allowHttpsRuleName')]",
            "properties": {
              "description": "Allow inbound HTTPS traffic on port 443",
              "priority": 100,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "443"
            }
          },
          {
            "name": "[variables('allowAzureServicesRuleName')]",
            "properties": {
              "description": "Allow inbound traffic from Azure platform services",
              "priority": 200,
              "protocol": "*",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "AzureCloud",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "*"
            }
          },
          {
            "name": "[variables('denyAllRuleName')]",
            "properties": {
              "description": "Deny all other inbound traffic — explicit default deny",
              "priority": 4096,
              "protocol": "*",
              "access": "Deny",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "*"
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "nsgResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/networkSecurityGroups', parameters('nsgName'))]"
    },
    "nsgName": {
      "type": "string",
      "value": "[parameters('nsgName')]"
    }
  }
}